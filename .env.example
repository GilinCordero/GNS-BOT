# GNS ISP API (Basic Auth)
GNS_BASE_URL=https://app.gns.com.mx/gns-sandbox
GNS_API_USER=your_gns_username
GNS_API_PASS=your_gns_password

# Gemini API
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash

# Servidor
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
# CRM y API en la misma VM → CORS_ORIGIN=* es suficiente.
# Si el CRM se mueve a otro dominio, cambiar a ese dominio específico.
CORS_ORIGIN=*

# Sesiones
SESSION_TTL_SECONDS=1800

# Cache global
CATEGORIES_TTL_SECONDS=3600
CUSTOMERS_TTL_SECONDS=300

# Búsqueda de clientes: máximo de resultados devueltos a Gemini
CUSTOMER_SEARCH_MAX_RESULTS=5

# Rate limiting
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW_MS=60000
