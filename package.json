{
  "name": "isp-chatbot",
  "version": "1.0.0",
  "type": "module",
  "engines": { "node": ">=20.0.0" },
  "scripts": {
    "dev":          "node --watch src/server.js",
    "start":        "node src/server.js",
    "build:widget": "esbuild widget/src/index.js --bundle --minify --outfile=widget/dist/widget.js --format=iife --global-name=ISPChatWidget --platform=browser --target=es2020",
    "build":        "npm run build:widget",
    "pm2:start":    "pm2 start ecosystem.config.cjs",
    "pm2:reload":   "pm2 reload isp-chatbot",
    "pm2:stop":     "pm2 stop isp-chatbot",
    "pm2:logs":     "pm2 logs isp-chatbot"
  },
  "dependencies": {
    "@fastify/cors":       "^10.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@google/genai":       "^1.0.0",
    "axios":               "^1.7.0",
    "dotenv":              "^16.0.0",
    "fastify":             "^5.0.0",
    "node-cache":          "^5.1.2",
    "uuid":                "^11.0.0"
  },
  "devDependencies": {
    "esbuild": "^0.24.0"
  }
}
